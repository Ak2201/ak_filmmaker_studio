{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/studio-store.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/studio", "destination": "/index.html" },
    { "source": "/feature", "destination": "/arunak-filmmaker-blueprint.html" },
    { "source": "/short", "destination": "/arunak-shortfilm-blueprint.html" },
    { "source": "/library", "destination": "/arunak-filmmaker-library.html" },
    { "source": "/shared/:token", "destination": "/index.html?share=:token" }
  ]
}
